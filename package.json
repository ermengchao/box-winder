{
  "name": "box-winder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:daemon": "bun run --cwd apps/daemon dev",
    "cli": "bun run --cwd apps/cli start",
    "bootstrap": "bun run --cwd apps/cli bootstrap",
    "systemd:env": "bun run --cwd apps/cli systemd:env",
    "db:migrate": "bun run --cwd packages/db migrate",
    "build": "bun run --cwd packages/core build && bun run --cwd packages/config build && bun run --cwd packages/contracts build && bun run --cwd packages/db build && bun run --cwd apps/api build && bun run --cwd apps/daemon build && bun run --cwd apps/cli build && bun run --cwd apps/web build",
    "typecheck": "bun run --cwd packages/core typecheck && bun run --cwd packages/config typecheck && bun run --cwd packages/contracts typecheck && bun run --cwd packages/db typecheck && bun run --cwd apps/api typecheck && bun run --cwd apps/daemon typecheck && bun run --cwd apps/cli typecheck && bun run --cwd apps/web typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@node-rs/argon2": "^2.0.2",
    "commander": "^14.0.2",
    "graphql": "^16.11.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^20",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "gitmoji-cli": "^9.7.0",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@node-rs/argon2",
    "sharp",
    "unrs-resolver"
  ]
}
