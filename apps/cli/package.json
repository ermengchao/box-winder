{
  "name": "@box-winder/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "box-winder": "./src/main.ts"
  },
  "scripts": {
    "bootstrap": "bun src/bootstrap-admin.ts",
    "systemd:env": "bun src/systemd-env.ts",
    "dev": "bun src/main.ts",
    "start": "bun src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check ."
  },
  "dependencies": {
    "@box-winder/config": "workspace:*",
    "@box-winder/contracts": "workspace:*",
    "@box-winder/core": "workspace:*",
    "@box-winder/db": "workspace:*"
  }
}
